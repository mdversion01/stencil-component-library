exports[`basic-slider-component parses tickValues from JSON attribute and shows tick labels: ticks-with-labels 1`] = `
<basic-slider-component tick-labels="" tick-values="[0,25,50,75,100]">
  <div class="slider-wrapper">
    <div class="slider" dir="ltr" role="presentation">
      <div class="slider-container">
        <div aria-labelledby="slider_flixze1nh-label" aria-readonly="true" class="slider-value-left" role="textbox">
          50%
        </div>
        <div aria-hidden="true" class="slider-min-value">
          0%
        </div>
        <div class="slider-controls" role="presentation">
          <div aria-hidden="true" class="slider-background-track" style="width: 100%;"></div>
          <div aria-hidden="true" class="slider-moving-track" style="width: 50%;"></div>
          <div aria-label="Slider" aria-orientation="horizontal" aria-valuemax="100" aria-valuemin="0" aria-valuenow="50" aria-valuetext="50%" class="slider-thumb-container" role="slider" tabindex="0" style="left: 50%; transition: all 0.1s cubic-bezier(0.25, 0.8, 0.5, 1) 0s;">
            <div aria-hidden="true" class="slider-thumb" role="presentation"></div>
          </div>
          <div aria-hidden="true" class="slider-ticks">
            <div>
              <div class="slider-tick" style="left: 0%; top: calc(50% - 10px);"></div>
              <div class="slider-tick-label" style="left: 0%; transform: translateX(-50%);">
                0%
              </div>
            </div>
            <div>
              <div class="slider-tick" style="left: 25%; top: calc(50% - 10px);"></div>
              <div class="slider-tick-label" style="left: 25%; transform: translateX(-50%);">
                25%
              </div>
            </div>
            <div>
              <div class="slider-tick" style="left: 50%; top: calc(50% - 10px);"></div>
              <div class="slider-tick-label" style="left: 50%; transform: translateX(-50%);">
                50%
              </div>
            </div>
            <div>
              <div class="slider-tick" style="left: 75%; top: calc(50% - 10px);"></div>
              <div class="slider-tick-label" style="left: 75%; transform: translateX(-50%);">
                75%
              </div>
            </div>
            <div>
              <div class="slider-tick" style="left: 100%; top: calc(50% - 10px);"></div>
              <div class="slider-tick-label" style="left: 100%; transform: translateX(-50%);">
                100%
              </div>
            </div>
          </div>
        </div>
        <div aria-hidden="true" class="slider-max-value">
          100%
        </div>
        <div aria-labelledby="slider_flixze1nh-label" aria-readonly="true" class="slider-value-right" role="textbox">
          50%
        </div>
      </div>
    </div>
  </div>
</basic-slider-component>
`;

