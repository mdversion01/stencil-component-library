exports[`basic-slider-component applies variant class to moving track and thumb container: variant-danger 1`] = `
<basic-slider-component>
  <div class="slider-wrapper">
    <div class="slider" dir="ltr" role="presentation">
      <div class="slider-container">
        <div aria-labelledby="slider_3coh0zmxo-label" aria-readonly="true" class="slider-value-left" role="textbox">
          20
        </div>
        <div aria-hidden="true" class="slider-min-value">
          0
        </div>
        <div class="slider-controls" role="presentation">
          <div aria-hidden="true" class="slider-background-track" style="width: 100%;"></div>
          <div aria-hidden="true" class="danger slider-moving-track" style="width: 20%;"></div>
          <div aria-label="Slider" aria-orientation="horizontal" aria-valuemax="100" aria-valuemin="0" aria-valuenow="20" aria-valuetext="20" class="danger slider-thumb-container" role="slider" tabindex="0" style="left: 20%; transition: all 0.1s cubic-bezier(0.25, 0.8, 0.5, 1) 0s;">
            <div aria-hidden="true" class="danger slider-thumb" role="presentation"></div>
          </div>
        </div>
        <div aria-hidden="true" class="slider-max-value">
          100
        </div>
        <div aria-labelledby="slider_3coh0zmxo-label" aria-readonly="true" class="slider-value-right" role="textbox">
          20
        </div>
      </div>
    </div>
  </div>
</basic-slider-component>
`;

