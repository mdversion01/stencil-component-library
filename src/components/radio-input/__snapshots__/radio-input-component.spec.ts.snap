exports[`radio-input-component shows validation message when no selection is made and required (group) 1`] = `
<radio-input-component bs-radio-group="" group-options="[{&quot;value&quot;:&quot;x&quot;,&quot;labelTxt&quot;:&quot;X&quot;,&quot;inputId&quot;:&quot;radio-x&quot;,&quot;checked&quot;:false,&quot;disabled&quot;:false},{&quot;value&quot;:&quot;y&quot;,&quot;labelTxt&quot;:&quot;Y&quot;,&quot;inputId&quot;:&quot;radio-y&quot;,&quot;checked&quot;:false,&quot;disabled&quot;:false}]" group-title="Validation Test" name="group1" required="" validation="" validation-msg="Please select one">
  <div class="radio-group radios was-validated">
    <div aria-describedby="radio-group-error-group1" aria-invalid="true" aria-labelledby="radio-group-title-group1" aria-required="true" role="radiogroup">
      <div class="group-title" id="radio-group-title-group1">
        Validation Test
        <span class="required">
          *
        </span>
      </div>
      <div class="form-group">
        <div class="form-check">
          <input aria-describedby="radio-group-error-group1" aria-invalid="true" class="form-check-input" id="radio-x" name="group1" required="" type="radio" value="x">
          <label class="form-check-label" htmlfor="radio-x">
            X
          </label>
        </div>
        <div class="form-check">
          <input aria-describedby="radio-group-error-group1" aria-invalid="true" class="form-check-input" id="radio-y" name="group1" required="" type="radio" value="y">
          <label class="form-check-label" htmlfor="radio-y">
            Y
          </label>
        </div>
      </div>
      <div aria-live="polite" class="form-text invalid-feedback" id="radio-group-error-group1" role="alert" style="display: block;">
        Please select one
      </div>
    </div>
  </div>
</radio-input-component>
`;
