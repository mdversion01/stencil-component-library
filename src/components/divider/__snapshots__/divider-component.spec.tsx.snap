exports[`divider-component uses explicit aria-label prop (attribute) when provided (text variant) 1`] = `
<divider-component aria-label="Section break" orientation="center">
  <!---->
  <div class="sc-divider">
    <div aria-label="Section break" aria-orientation="horizontal" class="divider divider-horizontal divider-with-text divider-with-text-center" role="separator">
      <span class="divider-inner-text">
        Center
      </span>
    </div>
  </div>
</divider-component>
