exports[`plumage-autocomplete-single required + blur marks invalid and shows validation message; underline reflects invalid state; aria-describedby wired to validation id 1`] = `
<plumage-autocomplete-single input-id="acs" validation-message="Please fill in">
  <div class="plumage">
    <div aria-atomic="true" aria-live="polite" class="sr-only" id="acs-live"></div>
    <div class="autocomplete-container form-group">
      <div>
        <label class="form-control-label invalid label-sm" htmlfor="acs" id="acs-label">
          <span class="required">
            City
          </span>
          <span class="required">
            *
          </span>
        </label>
        <div>
          <div class="autocomplete-single-select input-group is-invalid">
            <input aria-autocomplete="list" aria-controls="acs-listbox" aria-describedby="acs-validation" aria-disabled="false" aria-expanded="false" aria-haspopup="listbox" aria-invalid="true" aria-labelledby="acs-label" aria-required="true" autocomplete="off" class="form-control is-invalid" id="acs" inputmode="text" placeholder="City" role="combobox" type="text" value="">
          </div>
          <div class="b-underline invalid" role="presentation">
            <div aria-hidden="true" class="b-focus invalid" role="presentation" style="width: 0; left: 50%;"></div>
          </div>
          <div aria-live="polite" class="invalid-feedback" id="acs-validation">
            Please fill in
          </div>
        </div>
      </div>
    </div>
  </div>
</plumage-autocomplete-single>
`;
