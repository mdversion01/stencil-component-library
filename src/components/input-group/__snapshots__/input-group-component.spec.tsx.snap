exports[`<input-group-component> renders horizontal layout with responsive cols, prepend text and append icon 1`] = `
<input-group-component append-icon="fa-solid fa-dollar-sign" form-layout="horizontal" has-append="" has-prepend="" input-cols="xs-12 sm-8" input-id="amount" label="Amount" label-cols="xs-12 sm-4" prepend-text="Total">
  <div class="horizontal">
    <div class="form-group horizontal row">
      <label class="col-12 col-form-label col-sm-4 form-control-label label-sm no-padding" for="amount" id="amount__label">
        <span>
          Amount:
        </span>
      </label>
      <div class="col-12 col-sm-8">
        <div class="sr-only" id="amount__desc">
          Enter Amount. Type: text.
        </div>
        <div class="input-group">
          <span class="input-group-text">
            Total
          </span>
          <input aria-describedby="amount__desc" aria-labelledby="amount__label" class="form-control" id="amount" name="amount" placeholder="Amount" type="text" value="">
          <span class="input-group-text">
            <i aria-hidden="true" class="fa-dollar-sign fa-solid"></i>
          </span>
        </div>
      </div>
    </div>
  </div>
</input-group-component>
`;

