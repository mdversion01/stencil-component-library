exports[`<input-group-component> disables native affix buttons when readOnly=true 1`] = `
<input-group-component append-button="" append-text="Go" has-append="" has-prepend="" input-id="search-readonly" label="Search" prepend-button="" prepend-text="Back" read-only="">
  <div>
    <div class="form-group">
      <label class="form-control-label label-sm" for="search-readonly" id="search-readonly__label">
        <span>
          Search
        </span>
      </label>
      <div>
        <div class="sr-only" id="search-readonly__desc">
          Enter Search. Type: text.
        </div>
        <div class="input-group">
          <span class="prepend-btn">
            <button class="btn btn-secondary" disabled="" type="button">
              Back
            </button>
          </span>
          <input aria-describedby="search-readonly__desc" aria-labelledby="search-readonly__label" class="form-control" id="search-readonly" name="search" placeholder="Search" readonly="" type="text" value="">
          <span class="append-btn">
            <button class="btn btn-secondary" disabled="" type="button">
              Go
            </button>
          </span>
        </div>
      </div>
    </div>
  </div>
</input-group-component>
`;

exports[`<input-group-component> horizontal with numeric fallback cols and prop-driven text affixes snapshots correctly 1`] = `
<input-group-component append-text=".js" form-layout="horizontal" has-append="" has-prepend="" input-col="9" input-id="code" label="Code" label-col="3" prepend-text="#">
  <div class="horizontal">
    <div class="form-group horizontal row">
      <label class="col-3 col-form-label form-control-label label-sm no-padding" for="code" id="code__label">
        <span>
          Code:
        </span>
      </label>
      <div class="col-9">
        <div class="sr-only" id="code__desc">
          Enter Code. Type: text.
        </div>
        <div class="input-group">
          <span class="input-group-text">
            #
          </span>
          <input aria-describedby="code__desc" aria-labelledby="code__label" class="form-control" id="code" name="code" placeholder="Code" type="text" value="">
          <span class="input-group-text">
            .js
          </span>
        </div>
      </div>
    </div>
  </div>
</input-group-component>
`;

exports[`<input-group-component> mixes append button and prepend icon using side-specific props 1`] = `
<input-group-component append-button="" append-button-variant="secondary" append-text="Go" has-append="" has-prepend="" input-id="q" label="Search" prepend-icon="fa-solid fa-magnifying-glass">
  <div>
    <div class="form-group">
      <label class="form-control-label label-sm" for="q" id="q__label">
        <span>
          Search
        </span>
      </label>
      <div>
        <div class="sr-only" id="q__desc">
          Enter Search. Type: text.
        </div>
        <div class="input-group">
          <span class="input-group-text">
            <i aria-hidden="true" class="fa-magnifying-glass fa-solid"></i>
          </span>
          <input aria-describedby="q__desc" aria-labelledby="q__label" class="form-control" id="q" name="search" placeholder="Search" type="text" value="">
          <span class="append-btn">
            <button class="btn btn-secondary" type="button">
              Go
            </button>
          </span>
        </div>
      </div>
    </div>
  </div>
</input-group-component>
`;

