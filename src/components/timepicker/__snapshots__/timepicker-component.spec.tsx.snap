      <div aria-live="polite" class="hidden validation-message" id="my-time-validation" role="alert"></div>
      <div aria-live="polite" class="hidden warning-message" id="my-time-warning" role="alert">
        <i aria-hidden="true" class="fa fa-exclamation-triangle"></i>
        Time values cannot exceed the limits.
      </div>
    </div>
  </div>
</timepicker-component>
`;
