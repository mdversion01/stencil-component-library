exports[`timepicker-component disabled: disables input/buttons and dropdown stays hidden/inert 1`] = `
<timepicker-component disable-timepicker="" input-id="tp5">
  <div class="time-picker-container">
    <div class="mr-1 time-picker">
      <label class="sr-only" htmlfor="tp5">
        Enter Time
      </label>
      <div class="timepicker-group">
        <div class="input-group">
          <input aria-controls="tp5-dropdown" aria-expanded="false" aria-haspopup="dialog" aria-label="Time Picker" class="form-control time-input" disabled="" id="tp5" maxlength="8" name="time" placeholder="Enter Time" type="text" value="00:00:00">
          <button aria-label="Clear time" class="clear-button" disabled="" type="button">
            <i class="fa-times-circle fas"></i>
          </button>
          <button aria-controls="tp5-dropdown" aria-expanded="false" aria-haspopup="dialog" aria-label="Open time picker" class="input-group-text time-icon time-icon-btn" disabled="disabled" tabindex="0" type="button">
            <i class="fa fa-clock"></i>
          </button>
        </div>
        <div aria-modal="false" class="hidden time-dropdown" id="tp5-dropdown" inert="" role="dialog" tabindex="-1" style="pointer-events: none;">
          <div class="time-spinner-wrapper">
            <div class="time-spinner">
              <button aria-label="Increment hour" class="arrow up" data-type="hour" disabled="" type="button">
                <i class="fa-chevron-up fas"></i>
              </button>
              <span aria-label="Hour" aria-valuemax="23" aria-valuemin="0" aria-valuenow="0" aria-valuetext="00" class="hour-display" role="spinbutton" tabindex="-1">
                00
              </span>
              <button aria-label="Decrement hour" class="arrow down" data-type="hour" disabled="" type="button">
                <i class="fa-chevron-down fas"></i>
              </button>
            </div>
            <div aria-hidden="true" class="time-spinner-colon">
              <div class="dot">
                <i class="fa fa-circle"></i>
              </div>
              <div class="dot">
                <i class="fa fa-circle"></i>
              </div>
            </div>
            <div class="time-spinner">
              <button aria-label="Increment minute" class="arrow up" data-type="minute" disabled="" type="button">
                <i class="fa-chevron-up fas"></i>
              </button>
              <span aria-label="Minute" aria-valuemax="59" aria-valuemin="0" aria-valuenow="0" aria-valuetext="00" class="minute-display" role="spinbutton" tabindex="-1">
                00
              </span>
              <button aria-label="Decrement minute" class="arrow down" data-type="minute" disabled="" type="button">
                <i class="fa-chevron-down fas"></i>
              </button>
            </div>
            <div aria-hidden="true" class="time-spinner-colon">
              <div class="dot">
                <i class="fa fa-circle"></i>
              </div>
              <div class="dot">
                <i class="fa fa-circle"></i>
              </div>
            </div>
            <div class="time-spinner">
              <button aria-label="Increment second" class="arrow up" data-type="second" disabled="" type="button">
                <i class="fa-chevron-up fas"></i>
              </button>
              <span aria-label="Second" aria-valuemax="59" aria-valuemin="0" aria-valuenow="0" aria-valuetext="00" class="second-display" role="spinbutton" tabindex="-1">
                00
              </span>
              <button aria-label="Decrement second" class="arrow down" data-type="second" disabled="" type="button">
                <i class="fa-chevron-down fas"></i>
              </button>
            </div>
            <div aria-hidden="true" class="am-pm-spinner hidden time-spinner">
              <button aria-label="Toggle AM/PM" class="arrow up" data-type="ampm" disabled="" type="button">
                <i class="fa-chevron-up fas"></i>
              </button>
              <span aria-label="AM/PM" aria-valuemax="1" aria-valuemin="0" aria-valuenow="0" aria-valuetext="AM" class="ampm-display" role="spinbutton" tabindex="-1"></span>
              <button aria-label="Toggle AM/PM" class="arrow down" data-type="ampm" disabled="" type="button">
                <i class="fa-chevron-down fas"></i>
              </button>
            </div>
          </div>
          <div class="time-spinner-close">
            <button aria-label="Close" class="btn btn-outline-primary btn-sm btntext close-button" disabled="" type="button">
              Close
            </button>
          </div>
        </div>
        <button aria-label="Switch to 12 hour format" class="btn btn--outlined toggle-format-btn" disabled="disabled" type="button">
          <svg aria-hidden="true" class="format-btn" focusable="false" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <title>
              Switch to 12 Hour Format
            </title>
            <path d="M13 2V4C17 4.5 20 7.8 20 11.9C20 15.1 18.1 17.9 15.3 19.2L13 17V22H18L16.8 20.8C19.9 19.1 22 15.8 22 12C22 6.8 18 2.5 13 2M11 2C9.1 2.2 7.2 3 5.7 4.2L7.1 5.6C8.2 4.8 9.6 4.2 11 4V2M4.2 5.7C3 7.2 2.2 9.1 2 11H4C4.2 9.6 4.8 8.2 5.6 7.1L4.2 5.7M2 13C2.2 14.9 3 16.8 4.2 18.3L5.6 16.9C4.8 15.8 4.2 14.4 4 13H2M7.1 18.4L5.7 19.8C7.2 21 9.1 21.8 11 22V20C9.6 19.8 8.2 19.2 7.1 18.4M12 8V10H15V11H14C12.9 11 12 11.9 12 13V16H17V14H14V13H15C16.1 13 17 12.1 17 11V10C17 8.9 16.1 8 15 8H12M7 8V10H8V16H10V8H7Z"></path>
          </svg>
        </button>
      </div>
      <div aria-live="polite" class="hidden validation-message" id="tp5-validation" role="alert"></div>
      <div aria-live="polite" class="hidden warning-message" id="tp5-warning" role="alert">
        <i aria-hidden="true" class="fa fa-exclamation-triangle"></i>
        Time values cannot exceed the limits.
      </div>
    </div>
  </div>
</timepicker-component>
`;

