exports[`plumage-textarea-component renders validation + counter snapshot 1`] = `
<plumage-textarea-component label="Description" max-length="20" required="" rows="4" validation="" validation-message="Please enter a description." value="Hello">
  <div class="plumage">
    <div class="form-group">
      <label class="form-control-label invalid label-sm" for="plumage-ta-7vuryytx" id="plumage-ta-7vuryytx-label">
        <span>
          Description
        </span>
        <span class="required">
          *
        </span>
      </label>
      <div>
        <div class="input-container" role="presentation">
          <div class="sr-only" id="plumage-ta-7vuryytx-help">
            Enter Description. This is a multiline text area.
          </div><textarea aria-describedby="plumage-ta-7vuryytx-help plumage-ta-7vuryytx-validation plumage-ta-7vuryytx-counter" aria-invalid="true" aria-labelledby="plumage-ta-7vuryytx-label" aria-required="true" autocomplete="off" class="form-control is-invalid" id="plumage-ta-7vuryytx" maxlength="20" name="plumage-ta-7vuryytx" placeholder="Description" required="" rows="4" spellcheck="" value="Hello"></textarea>
          <div aria-hidden="true" class="b-underline invalid" role="presentation">
            <div aria-hidden="true" class="b-focus invalid" role="presentation" style="width: 0; left: 50%;"></div>
          </div>
          <div aria-atomic="true" aria-live="polite" class="form-text textarea-counter" id="plumage-ta-7vuryytx-counter">
            5 / 20
          </div>
          <div aria-live="polite" class="form-text invalid-feedback" id="plumage-ta-7vuryytx-validation">
            Please enter a description.
          </div>
        </div>
      </div>
    </div>
  </div>
</plumage-textarea-component>
`;

